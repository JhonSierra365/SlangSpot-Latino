{% load static %}
{% load socialaccount %}
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión - SlangSpot Latino</title>
    <link rel="icon" type="image/png" href="{% static 'core/images/slangspot-logo.png' %}">
    <link rel="stylesheet" href="{% static 'core/css/auth.css' %}">
</head>

<body>
    <div class="auth-hero-section">
        <div class="auth-container">
            <div class="auth-content">
                <div class="auth-header">
                    <div class="auth-logo">
                        <a href="/">
                            <img src="{% static 'core/images/slangspot-logo.png' %}" alt="SlangSpot Latino"
                                class="auth-logo-image">
                        </a>
                    </div>
                    <h1 class="auth-title">¡Bienvenido de vuelta!</h1>
                    <p class="auth-subtitle">Inicia sesión para continuar tu aventura con el español latino</p>
                </div>

                <div class="auth-form-container">
                    <form method="post" class="auth-form" novalidate>
                        {% csrf_token %}

                        {% if form.non_field_errors %}
                        <div class="auth-error">
                            <svg class="error-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd"
                                    d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            {{ form.non_field_errors|join:", " }}
                        </div>
                        {% endif %}

                        <div class="form-group">
                            <label for="{{ form.username.id_for_label }}" class="form-label">
                                <svg class="label-icon" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                Usuario
                            </label>
                            <div class="input-wrapper">
                                {{ form.username }}
                            </div>
                            {% for error in form.username.errors %}
                            <div class="field-error">
                                <svg class="error-icon" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd"
                                        d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                {{ error }}
                            </div>
                            {% endfor %}
                        </div>

                        <div class="form-group">
                            <label for="{{ form.password.id_for_label }}" class="form-label">
                                <svg class="label-icon" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd"
                                        d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                Contraseña
                            </label>
                            <div class="input-wrapper">
                                {{ form.password }}
                            </div>
                            {% for error in form.password.errors %}
                            <div class="field-error">
                                <svg class="error-icon" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd"
                                        d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
                                        clip-rule="evenodd"></path>
                                </svg>
                                {{ error }}
                            </div>
                            {% endfor %}
                        </div>

                        <button type="submit" class="auth-submit-btn">
                            <svg class="btn-icon" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd"
                                    d="M3 3a1 1 0 011 1v12a1 1 0 11-2 0V4a1 1 0 011-1zm7.707 3.293a1 1 0 010 1.414L9.414 9H17a1 1 0 110 2H9.414l1.293 1.293a1 1 0 01-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span>Iniciar Sesión</span>
                        </button>
                    </form>

                    <div class="auth-divider">
                        <span class="divider-line"></span>
                        <span class="divider-text">o continúa con</span>
                        <span class="divider-line"></span>
                    </div>

                    <div class="social-auth">
                        <a href="{% provider_login_url 'google' %}" class="social-btn google-btn">
                            <svg class="google-icon" viewBox="0 0 24 24">
                                <path fill="#4285F4"
                                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                <path fill="#34A853"
                                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                                <path fill="#FBBC05"
                                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                                <path fill="#EA4335"
                                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                            </svg>
                            <span>Continuar con Google</span>
                        </a>
                    </div>

                    <div class="auth-footer">
                        <p class="auth-redirect">
                            ¿No tienes una cuenta?
                            <a href="{% url 'core:register' %}" class="auth-link">Regístrate aquí</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>