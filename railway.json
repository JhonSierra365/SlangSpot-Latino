{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "python manage.py collectstatic --noinput"
  },
  "deploy": {
    "startCommand": "gunicorn slangspot.wsgi --log-file -",
    "releaseCommand": "python manage.py migrate --noinput"
  }
}
